{
  "transform": {
    "^.+\\.(t|j)sx?$": "ts-jest",
    "^.+\\.(js|jsx)$": "babel-jest"
  },
  "testRegex": "(src/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
  "testPathIgnorePatterns": ["/node_modules/", "/src/__tests__/fixtures/"],
  "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json", "node"],
  "setupFilesAfterEnv": ["<rootDir>/setupJest.ts"]
}
